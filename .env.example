# Template for local .env — copy to .env and fill in real values.
# The real .env is git-ignored. Do NOT commit secrets.

# Fencing Time Live login (used by the optional fencing scraper)
# Make a free account at https://www.fencingtimelive.com/account/signup
FTLIVE_EMAIL=
FTLIVE_PASSWORD=

# Path to a cookie jar exported from your logged-in browser (Netscape format).
# Used as an alternative to email/password if OAuth (Google/Facebook) was used.
FTLIVE_COOKIES_FILE=
